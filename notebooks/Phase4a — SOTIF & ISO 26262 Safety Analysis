,\n","    [47.9, 47.5, 46.8, 45.9, 44.6, 43.0, 40.8],\n","    [46.5, 46.1, 45.4, 44.5, 43.2, 41.6, 39.4],\n","    [44.2, 43.8, 43.1, 42.2, 40.9, 39.3, 37.1],\n","    [41.8, 41.4, 40.7, 39.8, 38.5, 36.9, 34.7],\n","    [39.1, 38.7, 38.0, 37.1, 35.8, 34.2, 32.0],\n","])\n","\n","# Planning mode matrix\n","def get_mode(cam_t, lid_t):\n","    combined = 1.0 - (0.6*cam_t + 0.4*lid_t)\n","    if combined > 0.6: return 'CONSERVATIVE'\n","    elif combined > 0.3: return 'CAUTIOUS'\n","    return 'NORMAL'\n","\n","# Reconstruct lidar trust\n","lidar_trust = np.array([\n","    [np.sqrt(1-d) for d in dropout_rates]\n","    for _ in glare_levels\n","])\n","# Normalize\n","for i in range(len(glare_levels)):\n","    for j in range(len(dropout_rates)):\n","        t = camera_trust[i,j] + lidar_trust[i,j]\n","        lidar_trust[i,j] = lidar_trust[i,j]/t * (camera_trust[i,j] + lidar_trust[i,j])\n","        camera_trust[i,j] = camera_trust[i,j]\n","\n","modes = [[get_mode(camera_trust[i,j], lidar_trust[i,j])\n","          for j in range(len(dropout_rates))]\n","         for i in range(len(glare_levels))]\n","\n","print(\"Phase 3 data loaded successfully\")\n","print(f\"Matrix shape: {camera_trust.shape}\")\n","print(f\"Glare levels: {glare_levels}\")\n","print(f\"Dropout rates: {dropout_rates}\")"],"metadata":{"id":"vyFnavpgjXjS","executionInfo":{"status":"ok","timestamp":1779484737386,"user_tz":-330,"elapsed":545,"user":{"displayName":"","userId":""}},"outputId":"53d94f42-dbb4-4730-b982-54ed5d1addf4","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Phase 3 data loaded successfully\n","Matrix shape: (7, 7)\n","Glare levels: [0.0, 0.15, 0.3, 0.45, 0.6, 0.75, 0.9]\n","Dropout rates: [0.0, 0.1, 0.2, 0.35, 0.5, 0.65, 0.8]\n"]}]},{"cell_type":"code","source":["# ── SOTIF TRIGGER CONDITION CATALOG (ISO 21448) ─────────────────────────────\n","\n","trigger_conditions = {\n","    'T1': {\n","        'name': 'Direct sunlight / glare',\n","        'description': 'Sun position causes camera sensor saturation in forward field of view',\n","        'sensor_affected': 'Camera',\n","        'glare_threshold': 0.30,\n","        'dropout_threshold': 0.0,\n","        'real_world_example': 'Morning/evening driving toward sun, tunnel exit',\n","        'iso_clause': 'ISO 21448 Cl. 8.3 - Known triggering conditions'\n","    },\n","    'T2': {\n","        'name': 'Rain / LiDAR point dropout',\n","        'description': 'Precipitation causes LiDAR beam attenuation and point cloud sparsity',\n","        'sensor_affected': 'LiDAR',\n","        'glare_threshold': 0.0,\n","        'dropout_threshold': 0.20,\n","        'real_world_example': 'Moderate to heavy rainfall, wet road spray',\n","        'iso_clause': 'ISO 21448 Cl. 8.3 - Known triggering conditions'\n","    },\n","    'T3': {\n","        'name': 'Combined degradation (glare + rain)',\n","        'description': 'Simultaneous camera glare and LiDAR dropout — worst case scenario',\n","        'sensor_affected': 'Camera + LiDAR',\n","        'glare_threshold': 0.30,\n","        'dropout_threshold': 0.20,\n","        'real_world_example': 'Rainy day driving toward low sun',\n","        'iso_clause': 'ISO 21448 Cl. 8.4 - Unknown triggering conditions'\n","    },\n","    'T4': {\n","        'name': 'Pedestrian crossing under sensor degradation',\n","        'description': 'Pedestrian present in path while primary sensor confidence is low',\n","        'sensor_affected': 'Camera + LiDAR',\n","        'glare_threshold': 0.45,\n","        'dropout_threshold': 0.35,\n","        'real_world_example': 'Crosswalk in direct sunlight with rain',\n","        'iso_clause': 'ISO 21448 Cl. 8.4 - Unknown triggering conditions'\n","    },\n","    'T5': {\n","        'name': 'Extreme combined sensor failure',\n","        'description': 'Both sensors operating below minimum reliability threshold simultaneously',\n","        'sensor_affected': 'Camera + LiDAR',\n","        'glare_threshold': 0.60,\n","        'dropout_threshold': 0.50,\n","        'real_world_example': 'Snowstorm at night near tunnel exit',\n","        'iso_clause': 'ISO 21448 Cl. 8.4 - Unknown triggering conditions'\n","    },\n","}\n","\n","print(\"SOTIF Trigger Condition Catalog\")\n","print(\"=\"*70)\n","for tid, tc in trigger_conditions.items():\n","    print(f\"\\n{tid}: {tc['name']}\")\n","    print(f\"  Sensor affected:    {tc['sensor_affected']}\")\n","    print(f\"  Threshold (glare):  {tc['glare_threshold']}\")\n","    print(f\"  Threshold (dropout):{tc['dropout_threshold']}\")\n","    print(f\"  Example:            {tc['real_world_example']}\")\n","    print(f\"  ISO 21448 clause:   {tc['iso_clause']}\")"],"metadata":{"id":"-HratQ2AjjyW","executionInfo":{"status":"ok","timestamp":1779484780246,"user_tz":-330,"elapsed":53,"user":{"displayName":"","userId":""}},"outputId":"480ac631-5232-441c-eb49-a9e0ccf06cf8","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["SOTIF Trigger Condition Catalog\n","======================================================================\n","\n","T1: Direct sunlight / glare\n","  Sensor affected:    Camera\n","  Threshold (glare):  0.3\n","  Threshold (dropout):0.0\n","  Example:            Morning/evening driving toward sun, tunnel exit\n","  ISO 21448 clause:   ISO 21448 Cl. 8.3 - Known triggering conditions\n","\n","T2: Rain / LiDAR point dropout\n","  Sensor affected:    LiDAR\n","  Threshold (glare):  0.0\n","  Threshold (dropout):0.2\n","  Example:            Moderate to heavy rainfall, wet road spray\n","  ISO 21448 clause:   ISO 21448 Cl. 8.3 - Known triggering conditions\n","\n","T3: Combined degradation (glare + rain)\n","  Sensor affected:    Camera + LiDAR\n","  Threshold (glare):  0.3\n","  Threshold (dropout):0.2\n","  Example:            Rainy day driving toward low sun\n","  ISO 21448 clause:   ISO 21448 Cl. 8.4 - Unknown triggering conditions\n","\n","T4: Pedestrian crossing under sensor degradation\n","  Sensor affected:    Camera + LiDAR\n","  Threshold (glare):  0.45\n","  Threshold (dropout):0.35\n","  Example:            Crosswalk in direct sunlight with rain\n","  ISO 21448 clause:   ISO 21448 Cl. 8.4 - Unknown triggering conditions\n","\n","T5: Extreme combined sensor failure\n","  Sensor affected:    Camera + LiDAR\n","  Threshold (glare):  0.6\n","  Threshold (dropout):0.5\n","  Example:            Snowstorm at night near tunnel exit\n","  ISO 21448 clause:   ISO 21448 Cl. 8.4 - Unknown triggering conditions\n"]}]},{"cell_type":"code","source":["# ── ISO 26262 HARA TABLE ─────────────────────────────────────────────────────\n","# Severity (S): S0=no injury, S1=light, S2=severe, S3=life-threatening\n","# Exposure (E): E1=very low, E2=low, E3=medium, E4=high\n","# Controllability (C): C0=always, C1=easy, C2=normal, C3=difficult\n","\n","hara_data = [\n","    {\n","        'hazard_id': 'H1',\n","        'trigger': 'T1',\n","        'trigger_name': 'Camera glare',\n","        'hazard': 'False positive pedestrian detection — unnecessary braking',\n","        'scenario': 'Urban intersection, morning sun, moderate traffic',\n","        'severity': 'S2', 'severity_val': 2,\n","        'exposure': 'E3', 'exposure_val': 3,\n","        'controllability': 'C2', 'controllability_val': 2,\n","        'asil': 'ASIL B',\n","        'asil_val': 2,\n","        'safety_goal': 'Perception confidence shall not trigger planning decisions when camera reliability < 0.5',\n","        'sotif_region': 'Known unsafe',\n","        'mitigation': 'Loop 1: LiDAR trust weight increases; Loop 2: velocity reduces to cautious profile'\n","    },\n","    {\n","        'hazard_id': 'H2',\n","        'trigger': 'T1',\n","        'trigger_name': 'Camera glare',\n","        'hazard': 'False negative — pedestrian missed in glare region',\n","        'scenario': 'Crosswalk in direct sunlight, pedestrian in saturated image region',\n","        'severity': 'S3', 'severity_val': 3,\n","        'exposure': 'E3', 'exposure_val': 3,\n","        'controllability': 'C3', 'controllability_val': 3,\n","        'asil': 'ASIL D',\n","        'asil_val': 4,\n","        'safety_goal': 'System shall enter CONSERVATIVE regime when camera confidence drops below threshold at pedestrian-present affordance',\n","        'sotif_region': 'Known unsafe',\n","        'mitigation': 'Loop 1: LiDAR assumes primary role; Loop 2: CONSERVATIVE mode + CBF hard constraint'\n","    },\n","    {\n","        'hazard_id': 'H3',\n","        'trigger': 'T2',\n","        'trigger_name': 'LiDAR rain dropout',\n","        'hazard': 'Range estimation error — incorrect distance to leading vehicle',\n","        'scenario': 'Highway following, moderate rain, LiDAR dropout > 35%',\n","        'severity': 'S2', 'severity_val': 2,\n","        'exposure': 'E4', 'exposure_val': 4,\n","        'controllability': 'C2', 'controllability_val': 2,\n","        'asil': 'ASIL C',\n","        'asil_val': 3,\n","        'safety_goal': 'TTC safety margin shall increase proportionally to LiDAR dropout rate',\n","        'sotif_region': 'Known unsafe',\n","        'mitigation': 'Loop 1: Camera range estimates weighted up; Loop 2: TTC margin increases from 2.0s to 4.5s'\n","    },\n","    {\n","        'hazard_id': 'H4',\n","        'trigger': 'T3',\n","        'trigger_name': 'Combined glare + rain',\n","        'hazard': 'Both sensors degraded — scene understanding unreliable',\n","        'scenario': 'Rainy day driving toward low sun, urban environment',\n","        'severity': 'S3', 'severity_val': 3,\n","        'exposure': 'E2', 'exposure_val': 2,\n","        'controllability': 'C3', 'controllability_val': 3,\n","        'asil': 'ASIL C',\n","        'asil_val': 3,\n","        'safety_goal': 'System shall enter CONSERVATIVE mode when combined sensor reliability < 0.35',\n","        'sotif_region': 'Unknown unsafe',\n","        'mitigation': 'Regime classifier triggers CONSERVATIVE; K(t)=0.15 — slow control response; RSS hard constraints active'\n","    },\n","    {\n","        'hazard_id': 'H5',\n","        'trigger': 'T4',\n","        'trigger_name': 'Pedestrian + degraded sensors',\n","        'hazard': 'Undetected pedestrian at crossing under combined sensor failure',\n","        'scenario': 'Crosswalk, glare > 0.45 AND LiDAR dropout > 35%',\n","        'severity': 'S3', 'severity_val': 3,\n","        'exposure': 'E2', 'exposure_val': 2,\n","        'controllability': 'C3', 'controllability_val': 3,\n","        'asil': 'ASIL D',\n","        'asil_val': 4,\n","        'safety_goal': 'Pedestrian affordance risk shall override uncertainty thresholding — same uncertainty triggers stricter regime when pedestrian present',\n","        'sotif_region': 'Unknown unsafe → Known unsafe via framework',\n","        'mitigation': 'Affordance-mediated regime: pedestrian_risk × uncertainty → CONSERVATIVE regardless of individual thresholds'\n","    },\n","    {\n","        'hazard_id': 'H6',\n","        'trigger': 'T5',\n","        'trigger_name': 'Extreme combined failure',\n","        'hazard': 'Complete perception unreliability — no safe scene understanding possible',\n","        'scenario': 'Snowstorm + night + tunnel exit, both sensors at minimum reliability',\n","        'severity': 'S3', 'severity_val': 3,\n","        'exposure': 'E1', 'exposure_val': 1,\n","        'controllability': 'C3', 'controllability_val': 3,\n","        'asil': 'ASIL B',\n","        'asil_val': 2,\n","        'safety_goal': 'System shall request MRC (Minimal Risk Condition) when both sensors below minimum threshold',\n","        'sotif_region': 'Unknown unsafe',\n","        'mitigation': 'K(t)=0.0 — freeze controls; MRC request; watchdog FSM triggers safe stop'\n","    },\n","]\n","\n","df = pd.DataFrame(hara_data)\n","print(\"HARA TABLE — ISO 26262 + SOTIF Analysis\")\n","print(\"=\"*80)\n","display_cols = ['hazard_id','trigger_name','hazard','severity','exposure',\n","                'controllability','asil','sotif_region']\n","print(df[display_cols].to_string(index=False))\n","print(f\"\\nTotal hazards identified: {len(hara_data)}\")\n","print(f\"ASIL D hazards: {sum(1 for h in hara_data if h['asil']=='ASIL D')}\")\n","print(f\"ASIL C hazards: {sum(1 for h in hara_data if h['asil']=='ASIL C')}\")\n","print(f\"ASIL B hazards: {sum(1 for h in hara_data if h['asil']=='ASIL B')}\")\n","print(f\"Unknown unsafe scenarios identified: {sum(1 for h in hara_data if 'Unknown' in h['sotif_region'])}\")"],"metadata":{"id":"8rP7ooh1juXi","executionInfo":{"status":"ok","timestamp":1779484846374,"user_tz":-330,"elapsed":105,"user":{"displayName":"","userId":""}},"outputId":"4331a9b3-bd91-4d51-f692-06573c3e4517","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["HARA TABLE — ISO 26262 + SOTIF Analysis\n","================================================================================\n","hazard_id                  trigger_name                                                                   hazard severity exposure controllability   asil                                sotif_region\n","       H1                  Camera glare                False positive pedestrian detection — unnecessary braking       S2       E3              C2 ASIL B                                Known unsafe\n","       H2                  Camera glare                       False negative — pedestrian missed in glare region       S3       E3              C3 ASIL D                                Known unsafe\n","       H3            LiDAR rain dropout           Range estimation error — incorrect distance to leading vehicle       S2       E4              C2 ASIL C                                Known unsafe\n","       H4         Combined glare + rain                   Both sensors degraded — scene understanding unreliable       S3       E2              C3 ASIL C                              Unknown unsafe\n","       H5 Pedestrian + degraded sensors          Undetected pedestrian at crossing under combined sensor failure       S3       E2              C3 ASIL D Unknown unsafe → Known unsafe via framework\n","       H6      Extreme combined failure Complete perception unreliability — no safe scene understanding possible       S3       E1              C3 ASIL B                              Unknown unsafe\n","\n","Total hazards identified: 6\n","ASIL D hazards: 2\n","ASIL C hazards: 2\n","ASIL B hazards: 2\n","Unknown unsafe scenarios identified: 3\n"]}]},{"cell_type":"code","source":["# ── FIGURE 1: SOTIF Known/Unknown Unsafe Classification Map ─────────────────\n","\n","def classify_sotif(glare, dropout):\n","    \"\"\"\n","    Classify each scenario cell into SOTIF regions:\n","    1 = Known safe\n","    2 = Known unsafe (identified trigger conditions)\n","    3 = Unknown unsafe (discovered by framework)\n","    4 = ASIL D — critical\n","    \"\"\"\n","    if glare >= 0.45 and dropout >= 0.35:\n","        if glare >= 0.60 and dropout >= 0.50:\n","            return 4  # ASIL D critical\n","        return 3  # Unknown unsafe\n","    elif glare >= 0.30 or dropout >= 0.20:\n","        return 2  # Known unsafe\n","    return 1  # Known safe\n","\n","sotif_map = np.array([[classify_sotif(g, d)\n","                       for d in dropout_rates]\n","                      for g in glare_levels])\n","\n","fig, axes = plt.subplots(1, 3, figsize=(20, 7))\n","\n","# Plot 1: SOTIF classification map\n","colors = ['#2ecc71', '#f39c12', '#e74c3c', '#8e44ad']\n","labels = ['Known safe', 'Known unsafe', 'Unknown unsafe', 'ASIL D critical']\n","cmap = ListedColormap(colors)\n","\n","im1 = axes[0].imshow(sotif_map, cmap=cmap, aspect='auto', vmin=1, vmax=4)\n","axes[0].set_xticks(range(len(dropout_rates)))\n","axes[0].set_xticklabels([f'{int(d*100)}%' for d in dropout_rates], fontsize=9)\n","axes[0].set_yticks(range(len(glare_levels)))\n","axes[0].set_yticklabels([f'{g:.2f}' for g in glare_levels], fontsize=9)\n","axes[0].set_xlabel('LiDAR dropout rate', fontsize=11)\n","axes[0].set_ylabel('Camera glare intensity', fontsize=11)\n","axes[0].set_title('SOTIF Scenario Classification\\n(ISO 21448 Region Mapping)',\n","                   fontsize=11, fontweight='bold')\n","\n","region_labels = ['', 'Known\\nsafe', 'Known\\nunsafe', 'Unknown\\nunsafe', 'ASIL D\\ncritical']\n","for i in range(len(glare_levels)):\n","    for j in range(len(dropout_rates)):\n","        val = sotif_map[i,j]\n","        color = 'white' if val >= 3 else 'black'\n","        axes[0].text(j, i, region_labels[val], ha='center', va='center',\n","                    fontsize=7, fontweight='bold', color=color)\n","\n","patches = [mpatches.Patch(color=colors[i], label=labels[i]) for i in range(4)]\n","axes[0].legend(handles=patches, loc='upper right', fontsize=8)\n","\n","# Plot 2: ASIL level per hazard\n","hazard_names = [f\"H{h['hazard_id'][1:]}: {h['trigger_name']}\" for h in hara_data]\n","asil_vals = [h['asil_val'] for h in hara_data]\n","asil_labels = [h['asil'] for h in hara_data]\n","asil_colors = ['#3498db', '#2ecc71', '#f39c12', '#e74c3c']\n","bar_colors = [asil_colors[v-1] for v in asil_vals]\n","\n","bars = axes[1].barh(range(len(hara_data)), asil_vals, color=bar_colors, alpha=0.85)\n","axes[1].set_yticks(range(len(hara_data)))\n","axes[1].set_yticklabels([h['hazard_id'] + ': ' + h['trigger_name'][:20]\n","                          for h in hara_data], fontsize=9)\n","axes[1].set_xticks([1,2,3,4])\n","axes[1].set_xticklabels(['ASIL A','ASIL B','ASIL C','ASIL D'], fontsize=9)\n","axes[1].set_title('ASIL Level per Hazard\\n(ISO 26262 HARA)', fontsize=11, fontweight='bold')\n","axes[1].grid(True, alpha=0.3, axis='x')\n","for i, (bar, label) in enumerate(zip(bars, asil_labels)):\n","    axes[1].text(bar.get_width() + 0.05, bar.get_y() + bar.get_height()/2,\n","                label, va='center', fontsize=9, fontweight='bold')\n","\n","# Plot 3: Safety goal coverage — which framework component addresses each hazard\n","framework_components = {\n","    'Loop 1\\n(Fusion trust)': [1,1,1,1,1,0],\n","    'Loop 2\\n(Planning adapt)': [1,1,1,1,1,1],\n","    'Affordance\\nregime': [0,1,0,1,1,0],\n","    'RSS/CBF\\nconstraints': [0,1,1,1,1,1],\n","    'MRC\\nwatchdog': [0,0,0,0,0,1],\n","}\n","\n","comp_names = list(framework_components.keys())\n","coverage = np.array(list(framework_components.values()))\n","\n","im3 = axes[2].imshow(coverage, cmap='RdYlGn', aspect='auto', vmin=0, vmax=1)\n","axes[2].set_xticks(range(len(hara_data)))\n","axes[2].set_xticklabels([h['hazard_id'] for h in hara_data], fontsize=10)\n","axes[2].set_yticks(range(len(comp_names)))\n","axes[2].set_yticklabels(comp_names, fontsize=9)\n","axes[2].set_xlabel('Hazard ID', fontsize=11)\n","axes[2].set_title('Framework Safety Coverage\\nWhich component mitigates each hazard',\n","                   fontsize=11, fontweight='bold')\n","for i in range(len(comp_names)):\n","    for j in range(len(hara_data)):\n","        val = coverage[i,j]\n","        axes[2].text(j, i, '✓' if val else '–', ha='center', va='center',\n","                    fontsize=12, color='white' if val else 'gray',\n","                    fontweight='bold')\n","\n","plt.suptitle('Phase 4: SOTIF & ISO 26262 Safety Analysis\\n'\n","             'Mapping Algorithmic Failure Modes to Safety Standards',\n","             fontsize=13, fontweight='bold')\n","plt.tight_layout()\n","plt.savefig('phase4_01_sotif_classification.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","print(\"Saved: phase4_01_sotif_classification.png\")\n","\n","# Count regions\n","regions = {1:0, 2:0, 3:0, 4:0}\n","for i in range(len(glare_levels)):\n","    for j in range(len(dropout_rates)):\n","        regions[sotif_map[i,j]] += 1\n","total = len(glare_levels) * len(dropout_rates)\n","print(f\"\\nSOTIF scenario space coverage ({total} total combinations):\")\n","print(f\"  Know